// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  password      String?   // null pour les comptes OAuth (Google, etc.)

  // --- OptiBot Core ---
  clientCount   Int       @default(0)
  isPro         Boolean   @default(false)
  role          String    @default("USER") // Global role: USER or ADMIN (System Admin)
  
  // --- Team ---
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  teamRole      String?   @default("MEMBER") // OWNER, ADMIN, MEMBER
  invitationsSent Invitation[]

  syncToken     String?   @unique @default(cuid())

  passwordChangedAt DateTime?

  // --- Plan ---
  plan          String    @default("FREE") // FREE, ESSENTIEL, PRO, EQUIPE

  // --- Scan limit (ESSENTIEL = 50/mois) ---
  monthlyScanCount   Int       @default(0)
  monthlyScanResetAt DateTime?

  // --- Stripe (Personal) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique

  onboardingStep Int      @default(0) // 0=inscrit, 1=extension, 2=premier doc, 3=copié, 4=rempli

  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())

  injectionLogs InjectionLog[]
  ocrFeedbacks  OcrFeedback[]
  ocrScanLogs   OcrScanLog[]
  dossiersTP    DossierTiersPayant[]
  alertesExpiration AlerteExpiration[]

  @@index([teamId])
  @@index([role])
  @@index([createdAt])
}

model Team {
  id            String    @id @default(cuid())
  name          String
  ownerId       String    // References User.id (logic enforced, not FK to avoid cycle/complexity initially, or we can make it FK)
  
  // --- Stripe (Team) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  plan                   String    @default("FREE") // FREE, PRO, ENTERPRISE

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  invitations   Invitation[]

  @@index([ownerId])
}

model Invitation {
  id            String    @id @default(cuid())
  email         String
  token         String    @unique
  role          String    @default("MEMBER")
  expires       DateTime
  
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  inviterId     String
  inviter       User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InjectionLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site        String
  success     Boolean
  fieldsCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model OcrFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  rawText   String   @db.Text
  fileName  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model OcrScanLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  success       Boolean
  ocrConfidence Float
  dataScore     Float
  globalScore   Float
  level         String
  fileName      String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([userId])
}

model RateLimit {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime

  @@map("rate_limits")
}

// ========================
// Tiers-Payant Module
// ========================

enum StatutDossierTP {
  EN_ATTENTE
  RECU
  REJETE
  EN_LITIGE
}

enum Mutuelle {
  CPAM
  ALMERYS
  VIAMEDIS
  ITELIS
  KALIXIA
  CARTE_BLANCHE
  SANTECLAIR
  SEVEANE
  SP_SANTE
  AUTRE
}

model DossierTiersPayant {
  id              String          @id @default(cuid())
  reference       String          @unique
  mutuelle        Mutuelle
  montant         Float
  dateEnvoi       DateTime
  numeroAdherent  String?
  referenceInterne String?
  statut          StatutDossierTP @default(EN_ATTENTE)

  montantRecu     Float?
  dateReception   DateTime?
  motifRejet      String?
  commentaire     String?         @db.Text

  relanceCount      Int           @default(0)
  derniereRelanceAt DateTime?
  relanceDesactivee Boolean       @default(false)

  lboDetailId     String?         @unique
  mode            String?

  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  historique      HistoriqueStatutTP[]
  relances        RelanceLog[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([statut])
  @@index([createdAt])
}

model HistoriqueStatutTP {
  id              String          @id @default(cuid())
  dossierId       String
  dossier         DossierTiersPayant @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  ancienStatut    StatutDossierTP
  nouveauStatut   StatutDossierTP
  commentaire     String?         @db.Text
  auteurId        String
  auteurNom       String
  createdAt       DateTime        @default(now())

  @@index([dossierId])
  @@index([createdAt])
}

model RegleRelance {
  id              String    @id @default(cuid())
  delaiJours      Int
  action          String    @default("both") // email, dashboard, both
  mutuelle        Mutuelle?
  actif           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([delaiJours, mutuelle])
}

model RelanceLog {
  id              String    @id @default(cuid())
  dossierId       String
  dossier         DossierTiersPayant @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type            String    // email, dashboard, both
  delaiJours      Int
  statut          String    @default("envoyee") // prevue, envoyee, reportee, annulee
  datePrevu       DateTime
  dateExecution   DateTime?
  createdAt       DateTime  @default(now())

  @@index([dossierId])
  @@index([statut])
  @@index([datePrevu])
}

model TemplateRelance {
  id              String    @id @default(cuid())
  nom             String
  type            String    @default("amiable") // amiable, ferme, mise_en_demeure
  objet           String
  contenu         String    @db.Text
  delaiJours      Int?
  actif           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AlerteExpiration {
  id                String    @id @default(cuid())
  dossierId         String?
  clientNom         String
  dateOrdonnance    DateTime
  dateExpiration    DateTime
  joursAvant        Int
  traitee           Boolean   @default(false)
  traiteePar        String?
  traiteeAt         DateTime?
  commentaire       String?   @db.Text
  notifEmail        Boolean   @default(false)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([traitee])
  @@index([dateExpiration])
}

model MutuelleEmailConfig {
  id              String    @id @default(cuid())
  mutuelle        Mutuelle  @unique
  emailDefaut     String
  emailPerso      String?
  actif           Boolean   @default(true)
  updatedAt       DateTime  @updatedAt
}

model RejetAutoDetecte {
  id              String    @id @default(cuid())
  syncToken       String
  portail         String    // ALMERYS, VIAMEDIS, ITELIS, KALIXIA
  numeroDossier   String?
  motif           String?
  dateRejet       DateTime?
  montant         Float?
  dossierId       String?
  matched         Boolean   @default(false)
  traite          Boolean   @default(false)
  rawData         String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([syncToken])
  @@index([traite])
  @@index([dossierId])
}

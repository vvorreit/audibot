// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  password      String?   // null pour les comptes OAuth (Google, etc.)

  // --- OptiBot Core ---
  clientCount   Int       @default(0)
  isPro         Boolean   @default(false)
  role          String    @default("USER") // Global role: USER or ADMIN (System Admin)
  
  // --- Team ---
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  teamRole      String?   @default("MEMBER") // OWNER, ADMIN, MEMBER
  invitationsSent Invitation[]

  syncToken     String?   @unique @default(cuid())

  passwordChangedAt DateTime?

  // --- Plan ---
  plan          String    @default("FREE") // FREE, ESSENTIEL, PRO, EQUIPE

  // --- Scan limit (ESSENTIEL = 50/mois) ---
  monthlyScanCount   Int       @default(0)
  monthlyScanResetAt DateTime?

  // --- Stripe (Personal) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique

  onboardingStep Int      @default(0) // 0=inscrit, 1=extension, 2=premier doc, 3=copié, 4=rempli

  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())

  injectionLogs InjectionLog[]
  ocrFeedbacks  OcrFeedback[]
  ocrScanLogs   OcrScanLog[]

  @@index([teamId])
  @@index([role])
  @@index([createdAt])
}

model Team {
  id            String    @id @default(cuid())
  name          String
  ownerId       String    // References User.id (logic enforced, not FK to avoid cycle/complexity initially, or we can make it FK)
  
  // --- Stripe (Team) ---
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  plan                   String    @default("FREE") // FREE, PRO, ENTERPRISE

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  invitations   Invitation[]

  @@index([ownerId])
}

model Invitation {
  id            String    @id @default(cuid())
  email         String
  token         String    @unique
  role          String    @default("MEMBER")
  expires       DateTime
  
  teamId        String
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  inviterId     String
  inviter       User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model InjectionLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site        String
  success     Boolean
  fieldsCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model OcrFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  rawText   String   @db.Text
  fileName  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model OcrScanLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  success       Boolean
  ocrConfidence Float
  dataScore     Float
  globalScore   Float
  level         String
  fileName      String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([userId])
}

model RateLimit {
  key       String   @id
  count     Int      @default(1)
  resetAt   DateTime

  @@map("rate_limits")
}
